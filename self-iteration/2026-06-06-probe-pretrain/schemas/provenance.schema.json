{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["sample_id", "research_config", "research_graph", "research_result", "label", "split"],
  "properties": {
    "sample_id": {"type": "string"},
    "batch_id": {"type": "string"},
    "topic_id": {"type": "string"},
    "rung_id": {"type": "integer"},
    "research_config": {"type": "object"},
    "label": {
      "type": "object",
      "properties": {
        "A1": {"type": "string"}, "A2": {"type": "string"}, "A3": {"type": "string"},
        "A4": {"type": "string"}, "A5": {"type": "string"}, "B1": {"type": "string"},
        "ladder_composite": {"type": "integer"}
      }
    },
    "research_graph": {"type": "object"},
    "research_result": {"type": "object"},
    "behavior_trace": {"type": "object"},
    "injection_fidelity": {"type": "object"},
    "manipulation_check": {"type": "object"},
    "completability": {"enum": ["ok", "failed"]},
    "gate_pass": {"type": "boolean"},
    "split": {"enum": ["train"]}
  }
}
