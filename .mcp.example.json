{
  "mcpServers": {
    "dare-agents": {
      "command": "npx",
      "args": ["--prefix", "/absolute/path/to/dare/packages/agents", "tsx", "/absolute/path/to/dare/packages/agents/src/server.ts"],
      "env": {
        "ANTHROPIC_BASE_URL": "https://api.anthropic.com",
        "ANTHROPIC_AUTH_TOKEN": "your-anthropic-api-key",
        "ANTHROPIC_MODEL": "claude-sonnet-4-20250514"
      }
    },
    "dare-scholar": {
      "command": "npx",
      "args": ["--prefix", "/absolute/path/to/dare/packages/scholar", "tsx", "/absolute/path/to/dare/packages/scholar/src/mcp_server.ts"],
      "env": {
        "MINERU_TOKEN": "your-mineru-token",
        "EMAIL": "your-email@example.com",
        "DARE_CACHE": "/absolute/path/to/cache",
        "OPENAI_API_KEY": "your-openai-compatible-api-key",
        "OPENAI_BASE_URL": "https://openrouter.ai/api/v1",
        "OPENAI_MODEL": "your-model-name"
      }
    },
    "dare-web": {
      "command": "npx",
      "args": ["--prefix", "/absolute/path/to/dare/packages/web", "tsx", "/absolute/path/to/dare/packages/web/src/mcp_server.ts"],
      "env": {
        "APIFY_TOKEN": "your-apify-token",
        "DARE_CACHE": "/absolute/path/to/cache"
      }
    },
    "dare-session": {
      "command": "npx",
      "args": ["--prefix", "/absolute/path/to/dare/packages/session", "tsx", "/absolute/path/to/dare/packages/session/src/mcp_server.ts"],
      "env": {
        "ANTHROPIC_BASE_URL": "https://api.anthropic.com",
        "ANTHROPIC_AUTH_TOKEN": "your-anthropic-api-key",
        "ANTHROPIC_MODEL": "claude-sonnet-4-20250514",
        "GITHUB_PAT": "your-github-pat",
        "HF_TOKEN": "your-huggingface-token"
      }
    },
    "dare-ss": {
      "command": "npx",
      "args": ["--prefix", "/absolute/path/to/dare/packages/ss", "tsx", "/absolute/path/to/dare/packages/ss/src/server.ts"],
      "env": {
        "SS_API_KEY": "your-semantic-scholar-api-key-or-remove-this-line"
      }
    },
    "apify": {
      "command": "npx",
      "args": ["-y", "@apify/actors-mcp-server", "--tools", "fetch-actor-details,get-actor-output,get-dataset-items,get-dataset-schema,marco.gullo/google-scholar-scraper,apify/rag-web-browser"],
      "env": {
        "APIFY_TOKEN": "your-apify-token"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server@latest"],
      "env": {
        "BRAVE_API_KEY": "your-brave-api-key"
      }
    },
    "runpod": {
      "command": "npx",
      "args": ["-y", "@runpod/mcp-server@latest"],
      "env": {
        "RUNPOD_API_KEY": "your-runpod-api-key"
      }
    },
    "alphaxiv": {
      "type": "http",
      "url": "https://api.alphaxiv.org/mcp/v1"
    }
  }
}
